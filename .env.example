# ==============================================================================
# NeuroStrategy OS - Sistema Operacional de IA Híbrida
# ==============================================================================
# Configurações alinhadas com o Documento Mestre (Custo Zero e IA Híbrida)
APP_URL=http://localhost:3000

# ==============================================================================
# TIER 1: NUVEM DE BAIXA LATÊNCIA (Groq / Llama 3)
# Papel (Doc): Desambiguação, Roteamento da próxima etapa e Planejamento lógico
# ==============================================================================
GROQ_API_KEY=your_key_here

# ==============================================================================
# TIER 2: OPENROUTER (Modelos Gratuitos Ilimitados / Fallback)
# Papel: Acesso a modelos vastos para raciocínio pesado ou fallback via tiers :free
# ==============================================================================
OPENROUTER_API_KEY=your_key_here

# ==============================================================================
# TIER 3: HUGGING FACE & MISTRAL (Serverless / Code-Agents)
# Papel (Doc): Suporte para code-agents (smolagents / Qwen 2.5) e testes serverless
# ==============================================================================
HF_API_KEY=your_key_here
MISTRAL_API_KEY=your_key_here

# ==============================================================================
# ROTEAMENTO E PREFERÊNCIAS (modelProvider.ts / backend)
# ==============================================================================
PRIMARY_MODEL=groq
BACKUP_MODEL=openrouter
OLLAMA_URL=http://localhost:11434

# ==============================================================================
# INTEGRAÇÕES DE ENGENHARIA E MEMÓRIA (NeuroEngine e Jules Bridge)
# ==============================================================================
JULES_API_KEY=your_key_here
V0_API_KEY=your_key_here
CONTEXT7_API_KEY=your_key_here
NEON_API_KEY=your_key_here
LINEAR_API_KEY=your_key_here
